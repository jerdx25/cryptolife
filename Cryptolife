function populateStates() {
  const country = document.getElementById('sel-country').value;
  const sel = document.getElementById('sel-state');
  sel.innerHTML = '';
  if (!country) { sel.innerHTML = '<option value="">-- Select Country First --</option>'; return; }
  const states = WORLD[country] || [];
  sel.appendChild(Object.assign(document.createElement('option'), {value:'', textContent:'-- Select Region --'}));
  states.forEach(s => sel.appendChild(Object.assign(document.createElement('option'), {value:s, textContent:s})));
}

