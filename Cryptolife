<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>CryptoLife</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1008;--parchment:#f5ede0;--cream:#fdf6ec;
  --warm1:#e8c99a;--warm2:#c9975a;--warm3:#8b5e2a;
  --accent:#c0392b;--accent2:#e67e22;--green:#27ae60;
  --blue:#2980b9;--purple:#8e44ad;--gold:#d4a017;
  --card:#fff9f0;--border:#d4b896;--shadow:rgba(26,16,8,.12);
}
html,body{height:100%;background:var(--parchment);font-family:'DM Sans',sans-serif;color:var(--ink);overflow-x:hidden}
#app{min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:0 0 40px}
.site-header{width:100%;background:var(--ink);padding:14px 20px;display:flex;align-items:center;justify-content:center}
.site-header h1{font-family:'Playfair Display',serif;font-size:28px;font-weight:900;color:var(--warm1);letter-spacing:3px;text-transform:uppercase}
.site-header .sub{font-size:10px;color:var(--warm3);letter-spacing:4px;text-align:center;margin-top:2px}
.game-wrap{width:100%;max-width:520px;padding:0 12px;margin-top:16px;display:flex;flex-direction:column;gap:14px}
.card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px;box-shadow:0 2px 12px var(--shadow)}
.card-title{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--warm3);margin-bottom:14px;font-weight:600}
.setup-grid{display:flex;flex-direction:column;gap:12px}
.field-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--warm3);display:block;margin-bottom:6px;font-weight:600}
.text-input{width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--ink);padding:11px 14px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color .2s}
.text-input:focus{border-color:var(--warm2)}
select.text-input{cursor:pointer}
.gender-row,.skin-row{display:flex;gap:8px;flex-wrap:wrap}
.opt-btn{flex:1;min-width:70px;background:var(--cream);border:1.5px solid var(--border);color:var(--warm3);padding:9px 6px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;text-align:center;letter-spacing:.5px}
.opt-btn.sel{border-color:var(--warm2);background:var(--warm1);color:var(--ink)}
.btn-start{width:100%;background:var(--ink);color:var(--warm1);border:none;padding:14px;border-radius:12px;font-family:'Playfair Display',serif;font-size:15px;font-weight:700;letter-spacing:2px;cursor:pointer;transition:all .2s;margin-top:4px}
.btn-start:hover{background:#2d1f0a;transform:scale(.99)}
.char-display{display:flex;align-items:center;gap:16px}
.avatar-wrap{width:90px;height:90px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:var(--parchment);border-radius:50%;border:2px solid var(--border);overflow:hidden}
.avatar-wrap svg{width:82px;height:82px}
.char-text{flex:1}
.char-name{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--ink)}
.char-meta{font-size:11px;color:var(--warm3);margin-top:3px;font-weight:500}
.char-money{font-size:14px;font-weight:600;color:var(--green);margin-top:4px}
.char-career{font-size:11px;color:var(--purple);margin-top:2px;font-weight:600;letter-spacing:.5px}
.loc-badge{font-size:11px;color:var(--blue);font-weight:600;margin-top:2px}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.stat{display:flex;flex-direction:column;gap:4px}
.stat-hdr{display:flex;justify-content:space-between}
.stat-lbl{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--warm3);font-weight:600}
.stat-val{font-size:11px;font-weight:700}
.stat-track{height:5px;background:#ede0cc;border-radius:3px;overflow:hidden}
.stat-fill{height:100%;border-radius:3px;transition:width .5s cubic-bezier(.4,0,.2,1)}
.fill-h{background:linear-gradient(90deg,#f39c12,#e67e22)}
.fill-hp{background:linear-gradient(90deg,#27ae60,#2ecc71)}
.fill-s{background:linear-gradient(90deg,#2980b9,#3498db)}
.fill-l{background:linear-gradient(90deg,#8e44ad,#9b59b6)}
.log-scroll{max-height:220px;overflow-y:auto;display:flex;flex-direction:column;gap:6px;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.log-scroll::-webkit-scrollbar{width:3px}
.log-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.log-entry{background:var(--cream);border-radius:8px;padding:9px 12px;display:flex;gap:10px;align-items:flex-start;border-left:3px solid var(--border);animation:popIn .2s ease;font-size:13px;line-height:1.5;color:#4a3520}
.log-entry.pos{border-left-color:var(--green)}.log-entry.neg{border-left-color:var(--accent)}
.log-entry.neu{border-left-color:var(--blue)}.log-entry.cho{border-left-color:var(--gold);color:#7a5c30;font-style:italic}
.log-entry.spe{border-left-color:var(--purple)}
.log-age{font-size:10px;color:var(--warm3);white-space:nowrap;padding-top:2px;font-weight:700;letter-spacing:1px}
@keyframes popIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.choice-prompt{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--warm3);margin-bottom:10px;font-weight:600}
.choice-list{display:flex;flex-direction:column;gap:7px}
.choice-btn{background:var(--cream);border:1.5px solid var(--border);color:var(--ink);padding:12px 14px;border-radius:10px;cursor:pointer;text-align:left;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;transition:all .18s;display:flex;align-items:center;gap:12px;line-height:1.4;width:100%}
.choice-btn:hover{border-color:var(--warm2);background:var(--warm1);transform:translateX(2px)}
.choice-icon{font-size:20px;flex-shrink:0;width:26px;text-align:center}
.choice-sub{font-size:10px;color:var(--warm3);margin-top:2px;letter-spacing:.5px;display:block;font-weight:500}
.career-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.career-btn{background:var(--cream);border:1.5px solid var(--border);color:var(--ink);padding:12px 10px;border-radius:10px;cursor:pointer;text-align:left;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;transition:all .2s;display:flex;align-items:center;gap:8px;width:100%}
.career-btn:hover{border-color:var(--warm2);background:var(--warm1)}
.career-btn .ci{font-size:22px;flex-shrink:0}
.career-btn .cn{display:flex;flex-direction:column}
.career-btn .cs{font-size:10px;color:var(--warm3);font-weight:400;margin-top:1px}
.btn-age{width:100%;background:var(--ink);color:var(--warm1);border:none;padding:13px;border-radius:12px;font-family:'Playfair Display',serif;font-size:14px;font-weight:700;letter-spacing:2px;cursor:pointer;transition:all .2s;text-transform:uppercase}
.btn-age:hover{background:#2d1f0a}
.btn-age:disabled{background:#c4b5a0;color:#a09080;cursor:not-allowed}
.btn-new{width:100%;background:transparent;color:var(--warm3);border:1.5px solid var(--border);padding:11px;border-radius:12px;font-family:'DM Sans',sans-serif;font-size:12px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .2s;font-weight:600}
.btn-new:hover{border-color:var(--warm2);color:var(--warm2)}
.tab-row{display:flex;gap:0;border:1.5px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px}
.tab-btn{flex:1;padding:9px 4px;background:var(--cream);border:none;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:600;color:var(--warm3);cursor:pointer;letter-spacing:.5px;transition:all .2s;border-right:1px solid var(--border)}
.tab-btn:last-child{border-right:none}
.tab-btn.active{background:var(--ink);color:var(--warm1)}
.overlay{display:none;position:fixed;inset:0;background:rgba(26,16,8,.88);z-index:200;align-items:center;justify-content:center;padding:20px}
.overlay.show{display:flex}
.death-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:28px 24px;max-width:400px;width:100%;text-align:center;display:flex;flex-direction:column;gap:14px}
.death-em{font-size:52px}.death-name{font-family:'Playfair Display',serif;font-size:20px;font-weight:700}
.death-sub{font-size:13px;color:var(--warm3);line-height:1.6}
.death-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;text-align:left}
.death-stat{background:var(--cream);border-radius:8px;padding:10px 12px}
.death-stat-l{font-size:9px;letter-spacing:2px;color:var(--warm3);text-transform:uppercase;font-weight:600}
.death-stat-v{font-size:15px;font-weight:700;color:var(--ink);margin-top:2px}
.career-status{background:var(--cream);border-radius:10px;padding:12px 14px;border:1px solid var(--border);margin-bottom:10px}
.cs-title{font-size:11px;letter-spacing:2px;color:var(--warm3);text-transform:uppercase;font-weight:600;margin-bottom:6px}
.cs-body{font-size:13px;font-weight:600;color:var(--ink)}
.cs-detail{font-size:12px;color:var(--warm3);margin-top:2px}
.skill-row2{display:flex;align-items:center;gap:8px;margin-top:6px}
.skill-lbl{font-size:10px;color:var(--warm3);width:60px;flex-shrink:0;letter-spacing:.5px}
.skill-track{flex:1;height:5px;background:#ede0cc;border-radius:3px;overflow:hidden}
.skill-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--warm2),var(--gold));transition:width .4s}
.skill-num{font-size:10px;color:var(--warm3);width:24px;text-align:right}
.hidden{display:none!important}
</style>
</head>
<body>
<div id="app">
<div class="site-header">
  <div style="text-align:center">
    <h1>CryptoLife</h1>
    <div class="sub">live every chapter</div>
  </div>
</div>
<div class="game-wrap">

  <div class="card" id="setup-card">
    <div class="card-title">Create Your Character</div>
    <div class="setup-grid">
      <div>
        <span class="field-label">Name</span>
        <input class="text-input" id="inp-name" placeholder="Enter name..." maxlength="20">
      </div>
      <div>
        <span class="field-label">Gender</span>
        <div class="gender-row">
          <button class="opt-btn sel" id="g-female" onclick="setGender('female')">&#9792; Female</button>
          <button class="opt-btn" id="g-male" onclick="setGender('male')">&#9794; Male</button>
        </div>
      </div>
      <div>
        <span class="field-label">Skin Tone</span>
        <div class="skin-row">
          <button class="opt-btn sel" id="sk-light" onclick="setSkin('light')">Light</button>
          <button class="opt-btn" id="sk-tan" onclick="setSkin('tan')">Tan</button>
          <button class="opt-btn" id="sk-medium" onclick="setSkin('medium')">Medium</button>
          <button class="opt-btn" id="sk-dark" onclick="setSkin('dark')">Dark</button>
        </div>
      </div>
      <div>
        <span class="field-label">Country</span>
        <select class="text-input" id="sel-country" onchange="populateStates()">
          <option value="">-- Select Country --</option>
        </select>
      </div>
      <div>
        <span class="field-label">State / Province / Region</span>
        <select class="text-input" id="sel-state">
          <option value="">-- Select Country First --</option>
        </select>
      </div>
      <button class="btn-start" onclick="startGame()">Begin Your Life</button>
    </div>
  </div>

  <div class="card hidden" id="char-card">
    <div class="char-display">
      <div class="avatar-wrap" id="avatar-wrap"></div>
      <div class="char-text">
        <div class="char-name" id="char-name">-</div>
        <div class="char-meta" id="char-meta">Newborn - Age 0</div>
        <div class="loc-badge" id="char-loc"></div>
        <div class="char-money" id="char-money">$0</div>
        <div class="char-career" id="char-career"></div>
      </div>
    </div>
  </div>

  <div class="card hidden" id="stats-card">
    <div class="card-title">Stats</div>
    <div class="stats-grid">
      <div class="stat">
        <div class="stat-hdr"><span class="stat-lbl">Happiness</span><span class="stat-val" id="v-h" style="color:#e67e22">-</span></div>
        <div class="stat-track"><div class="stat-fill fill-h" id="b-h" style="width:0%"></div></div>
      </div>
      <div class="stat">
        <div class="stat-hdr"><span class="stat-lbl">Health</span><span class="stat-val" id="v-hp" style="color:#27ae60">-</span></div>
        <div class="stat-track"><div class="stat-fill fill-hp" id="b-hp" style="width:0%"></div></div>
      </div>
      <div class="stat">
        <div class="stat-hdr"><span class="stat-lbl">Smarts</span><span class="stat-val" id="v-s" style="color:#2980b9">-</span></div>
        <div class="stat-track"><div class="stat-fill fill-s" id="b-s" style="width:0%"></div></div>
      </div>
      <div class="stat">
        <div class="stat-hdr"><span class="stat-lbl">Looks</span><span class="stat-val" id="v-l" style="color:#8e44ad">-</span></div>
        <div class="stat-track"><div class="stat-fill fill-l" id="b-l" style="width:0%"></div></div>
      </div>
    </div>
  </div>

  <div class="card hidden" id="main-panel">
    <div class="tab-row">
      <button class="tab-btn active" onclick="showTab('life')">Life</button>
      <button class="tab-btn" onclick="showTab('careers')">Career</button>
      <button class="tab-btn" onclick="showTab('crime')">Crime</button>
    </div>
    <div id="tab-life">
      <div class="card-title">Life Events</div>
      <div class="log-scroll" id="log"></div>
    </div>
    <div id="tab-careers" class="hidden">
      <div class="card-title">Choose Your Path</div>
      <div id="career-status-area"></div>
      <div class="career-grid" id="career-grid"></div>
    </div>
    <div id="tab-crime" class="hidden">
      <div class="card-title">Criminal Activities</div>
      <div id="crime-status-area"></div>
      <div class="career-grid" id="crime-grid"></div>
    </div>
  </div>

  <div class="card hidden" id="choice-card">
    <div class="choice-prompt">What do you do?</div>
    <div class="choice-list" id="choice-list"></div>
  </div>

  <div class="hidden" id="action-area" style="flex-direction:column;gap:8px">
    <button class="btn-age" id="btn-age" onclick="ageUp()">Age Up</button>
    <button class="btn-new" onclick="resetGame()">New Character</button>
  </div>
</div>

<div class="overlay" id="death-overlay">
  <div class="death-card">
    <div class="death-em" id="death-em">RIP</div>
    <div class="death-name" id="death-name"></div>
    <div class="death-sub" id="death-sub"></div>
    <div class="death-grid" id="death-grid"></div>
    <button class="btn-start" onclick="resetGame()">Live Again</button>
  </div>
</div>

