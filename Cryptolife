// ============================================================
//  STATE
// ============================================================
let G = null;
let selectedGender = 'female';
let selectedSkin   = 'light';
let waiting        = false;

function setGender(g) {
  selectedGender = g;
  ['female','male'].forEach(x => document.getElementById('g-'+x).classList.toggle('sel', x===g));
}
function setSkin(sk) {
  selectedSkin = sk;
  ['light','tan','medium','dark'].forEach(x => document.getElementById('sk-'+x).classList.toggle('sel', x===sk));
}

// ============================================================
//  START GAME
// ============================================================
function startGame() {
  const country = document.getElementById('sel-country').value;
  const state   = document.getElementById('sel-state').value;
  if (!country) { alert('Please select your country!'); return; }
  if (!state)   { alert('Please select your region!');  return; }
  const name = document.getElementById('inp-name').value.trim() || (selectedGender==='female'?'Aria':'Marcus');
  G = {
    name, age:0, isFemale:selectedGender==='female', skin:selectedSkin,
    country, state,
    happiness:rand(55,80), health:rand(70,92), smarts:rand(35,68), looks:rand(35,68),
    money:rand(0,500), fame:0,
    career:null, careerName:'', careerSkill:0, careerSeason:0,
    crimeCareer:null, crimeName:'', crimeSkill:0, heatLevel:0,
    arrests:0, alive:true, lifespan:rand(72,96), seenEvents:[],
  };
  document.getElementById('setup-card').classList.add('hidden');
  ['char-card','stats-card','main-panel'].forEach(id => document.getElementById(id).classList.remove('hidden'));
  const aa = document.getElementById('action-area');
  aa.classList.remove('hidden'); aa.style.display = 'flex';
  renderAll();
  addLog('Born in ' + G.state + ', ' + G.country + '. A new life begins!', 'pos');
  buildCareerGrid(); buildCrimeGrid();
}

// ============================================================
//  RENDER
// ============================================================
function renderAll() {
  document.getElementById('avatar-wrap').innerHTML = getAvatar(G);
  document.getElementById('char-name').textContent = G.name;
  const stage = G.age<3?'Baby':G.age<6?'Toddler':G.age<13?'Child':G.age<18?'Teenager':G.age<26?'Young Adult':G.age<51?'Adult':'Elder';
  document.getElementById('char-meta').textContent = stage + ' - Age ' + G.age;
  document.getElementById('char-loc').textContent  = G.state + ', ' + G.country;
  document.getElementById('char-money').textContent = '$' + G.money.toLocaleString();
  const cc = document.getElementById('char-career');
  cc.textContent = G.career ? (G.careerName + '  |  Skill: ' + G.careerSkill)
    : G.crimeCareer ? (G.crimeName + '  |  Heat: ' + G.heatLevel + '%') : '';
  const sm = {h:'happiness',hp:'health',s:'smarts',l:'looks'};
  for (const [k,p] of Object.entries(sm)) {
    const v = G[p]||0;
    document.getElementById('v-'+k).textContent = v;
    document.getElementById('b-'+k).style.width = v + '%';
  }
  updateCareerStatus(); updateCrimeStatus();
}

function addLog(text, type) {
  type = type || 'neu';
  const log = document.getElementById('log');
  const d = document.createElement('div');
  d.className = 'log-entry ' + type;
  d.innerHTML = '<span class="log-age">yr ' + String(G.age).padStart(2,'0') + '</span><span>' + text + '</span>';
  log.appendChild(d);
  d.scrollIntoView({behavior:'smooth',block:'end'});
}

function showTab(tab) {
  ['life','careers','crime'].forEach(t => document.getElementById('tab-'+t).classList.toggle('hidden', t!==tab));
  document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', ['life','careers','crime'][i]===tab));
}

// ============================================================
//  AGE UP
// ============================================================
function ageUp() {
  if (waiting) return;
  G.age++;
  G.happiness = clamp(G.happiness + rand(-4,4));
  G.health    = clamp(G.health    + (G.age>60 ? rand(-6,-1) : rand(-2,2)));
  G.smarts    = clamp(G.smarts    + (G.health>50 ? rand(-1,2) : rand(-2,0)));
  G.looks     = clamp(G.looks     + (G.age>35 ? rand(-3,0) : rand(-1,1)));

  if (G.career) {
    const c = CAREERS.find(function(x){return x.id===G.career;});
    if (c) {
      const earn = Math.floor(c.salary*(0.8+G.careerSkill/200));
      G.money += earn; G.careerSkill = clamp(G.careerSkill+rand(1,4));
      G.careerSeason++; G.fame = clamp(G.fame+rand(1,3));
      addLog(c.name + ' season ' + G.careerSeason + ' done. Earned $' + earn.toLocaleString() + '. Skill: ' + G.careerSkill, 'spe');
    }
  }
  if (G.crimeCareer) {
    const c = CRIME_CAREERS.find(function(x){return x.id===G.crimeCareer;});
    if (c) {
      if (Math.random() < c.risk*(G.heatLevel/100+0.1)) {
        G.arrests++;
        G.heatLevel = clamp(G.heatLevel-20);
        const bail = rand(5000,20000); G.money = Math.max(0,G.money-bail);
        addLog('ARRESTED! $' + bail.toLocaleString() + ' bail. Arrests: ' + G.arrests, 'neg');
        if (G.arrests>=3){ addLog('Sentenced to life in prison.','neg'); setTimeout(function(){triggerDeath('incarceration');},600); return; }
      } else {
        const earn = Math.floor(c.reward*rand(5,15)/10);
        G.money+=earn; G.crimeSkill=clamp(G.crimeSkill+rand(1,3)); G.heatLevel=clamp(G.heatLevel+rand(3,8));
        addLog(c.name + ' operations netted $' + earn.toLocaleString() + '. Heat: ' + G.heatLevel + '%', 'spe');
      }
    }
  }

  if (G.age>=G.lifespan||G.health<=0) { setTimeout(function(){triggerDeath(G.health<=0?'health failure':'old age');},500); return; }

  renderAll(); showTab('life');

  const eligible = EVENTS.filter(function(e){ return G.age>=(e.min||0)&&G.age<=(e.max||99)&&G.seenEvents.indexOf(e.text)<0; });
  if (!eligible.length){ addLog('Another quiet year passes.','neu'); return; }
  const ev = eligible[Math.floor(Math.random()*eligible.length)];
  G.seenEvents.push(ev.text);
  if (G.seenEvents.length>12) G.seenEvents.shift();
  addLog(G.name + ' turns ' + G.age + '.', 'neu');
  addLog(ev.text, ev.type);
  showChoices(ev.choices);
}

// ============================================================
//  CHOICES
// ============================================================
function showChoices(choices) {
  waiting = true;
  document.getElementById('btn-age').disabled = true;
  const card = document.getElementById('choice-card');
  const list = document.getElementById('choice-list');
  card.classList.remove('hidden');
  list.innerHTML = '';
  choices.forEach(function(c) {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    btn.innerHTML = '<span class="choice-icon">' + c.icon + '</span><span>' + c.t + '<span class="choice-sub">' + (c.sub||'') + '</span></span>';
    btn.onclick = function(){ applyChoice(c); };
    list.appendChild(btn);
  });
  card.scrollIntoView({behavior:'smooth',block:'nearest'});
}

function applyChoice(c) {
  const e = c.e||{};
  if (e.hp!==undefined)     G.happiness = clamp(G.happiness+e.hp);
  if (e.health!==undefined) G.health    = clamp(G.health+e.health);
  if (e.s!==undefined)      G.smarts    = clamp(G.smarts+e.s);
  if (e.l!==undefined)      G.looks     = clamp(G.looks+e.l);
  if (e.money!==undefined)  G.money     = Math.max(0,G.money+e.money);
  if (e.fame!==undefined)   G.fame      = clamp(G.fame+e.fame);
  const fx = Object.keys(e).map(function(k){ const v=e[k]; return (v>0?'+':'')+v+' '+k; }).join('  ');
  addLog('You chose: ' + c.t + '  (' + fx + ')', 'cho');
  document.getElementById('choice-card').classList.add('hidden');
  waiting = false;
  document.getElementById('btn-age').disabled = false;
  renderAll();
}

// ============================================================
//  CAREERS
// ============================================================
function buildCareerGrid() {
  const grid = document.getElementById('career-grid');
  grid.innerHTML = '';
  CAREERS.forEach(function(c) {
    const btn = document.createElement('button');
    btn.className = 'career-btn';
    btn.innerHTML = '<span class="ci">[' + c.icon + ']</span><span class="cn"><span>' + c.name + '</span><span class="cs">' + c.sub + '</span></span>';
    btn.onclick = function(){ startCareer(c); };
    grid.appendChild(btn);
  });
}

function startCareer(c) {
  if (G.age<c.minAge){ alert('Must be ' + c.minAge + '+ for this career.'); return; }
  if (c.req) {
    const keys = Object.keys(c.req);
    for (let i=0;i<keys.length;i++) {
      const k=keys[i], v=c.req[k];
      const val = k==='s'?G.smarts:k==='health'?G.health:G.looks;
      if (val<v){ alert('Need ' + (k==='s'?'Smarts':k==='health'?'Health':'Looks') + ' >= ' + v + '.'); return; }
    }
  }
  G.career=c.id; G.careerName=c.name; G.careerSkill=10; G.careerSeason=0;
  G.crimeCareer=null; G.crimeName='';
  addLog('Signed on as: ' + c.name + '! First season begins.', 'spe');
  renderAll(); showTab('careers');
}

function updateCareerStatus() {
  const area = document.getElementById('career-status-area');
  if (!G||!G.career){ area.innerHTML=''; return; }
  const c = CAREERS.find(function(x){return x.id===G.career;});
  if (!c) return;
  area.innerHTML = '<div class="career-status"><div class="cs-title">Active Career</div><div class="cs-body">' + c.name + '</div><div class="cs-detail">Season ' + G.careerSeason + '  ~$' + c.salary.toLocaleString() + '/yr  Fame: ' + G.fame + '</div><div class="skill-row2"><div class="skill-lbl">' + c.skillName + '</div><div class="skill-track"><div class="skill-fill" style="width:' + G.careerSkill + '%"></div></div><div class="skill-num">' + G.careerSkill + '</div></div><button class="choice-btn" style="margin-top:10px;font-size:12px" onclick="retireCareer()">Retire / Quit</button></div>';
}

function retireCareer() {
  addLog('Retired from ' + G.careerName + '.','neu');
  G.career=null; G.careerName=''; G.careerSkill=0; renderAll();
}

// ============================================================
//  CRIME
// ============================================================
function buildCrimeGrid() {
  const grid = document.getElementById('crime-grid');
  grid.innerHTML = '';
  CRIME_CAREERS.forEach(function(c) {
    const btn = document.createElement('button');
    btn.className = 'career-btn';
    btn.innerHTML = '<span class="ci">[' + c.icon + ']</span><span class="cn"><span>' + c.name + '</span><span class="cs">' + c.sub + '</span></span>';
    btn.onclick = function(){ startCrime(c); };
    grid.appendChild(btn);
  });
}

function startCrime(c) {
  if (G.age<c.minAge){ alert('Must be ' + c.minAge + '+ for this.'); return; }
  if (c.req) {
    const keys = Object.keys(c.req);
    for (let i=0;i<keys.length;i++) {
      const k=keys[i], v=c.req[k];
      const val = k==='s'?G.smarts:G.looks;
      if (val<v){ alert('Need ' + (k==='s'?'Smarts':'Looks') + ' >= ' + v + '.'); return; }
    }
  }
  G.crimeCareer=c.id; G.crimeName=c.name; G.crimeSkill=5; G.heatLevel=10;
  G.career=null; G.careerName='';
  addLog('Entered the criminal underworld: ' + c.name + '. Watch your back.', 'neg');
  renderAll(); showTab('crime');
}

function updateCrimeStatus() {
  const area = document.getElementById('crime-status-area');
  if (!G||!G.crimeCareer){ area.innerHTML=''; return; }
  const c = CRIME_CAREERS.find(function(x){return x.id===G.crimeCareer;});
  if (!c) return;
  const hc = G.heatLevel>70?'var(--accent)':G.heatLevel>40?'var(--accent2)':'var(--green)';
  area.innerHTML = '<div class="career-status"><div class="cs-title">Criminal Operation</div><div class="cs-body">' + c.name + '</div><div class="cs-detail">Arrests: ' + G.arrests + '  ~$' + c.reward.toLocaleString() + '/yr potential</div><div class="skill-row2"><div class="skill-lbl">' + c.skillName + '</div><div class="skill-track"><div class="skill-fill" style="width:' + G.crimeSkill + '%"></div></div><div class="skill-num">' + G.crimeSkill + '</div></div><div class="skill-row2"><div class="skill-lbl">Heat</div><div class="skill-track"><div class="skill-fill" style="width:' + G.heatLevel + '%;background:' + hc + '"></div></div><div class="skill-num" style="color:' + hc + '">' + G.heatLevel + '</div></div><button class="choice-btn" style="margin-top:10px;font-size:12px" onclick="quitCrime()">Go Straight</button></div>';
}

function quitCrime() {
  addLog('Walked away from the criminal life.','neu');
  G.crimeCareer=null; G.crimeName=''; renderAll();
}

// ============================================================
//  DEATH
// ============================================================
function triggerDeath(cause) {
  document.getElementById('death-name').textContent = G.name + ' - Age ' + G.age;
  document.getElementById('death-sub').textContent  = 'Cause: ' + cause + '. A life from ' + G.state + ', ' + G.country + '.';
  const stats=[['Age',G.age],['Happiness',G.happiness+'/100'],['Health',G.health+'/100'],
    ['Smarts',G.smarts+'/100'],['Looks',G.looks+'/100'],['Net Worth','$'+G.money.toLocaleString()],
    ['Fame',G.fame],['Arrests',G.arrests],['Career',G.careerName||G.crimeName||'None'],['Hometown',G.state]];
  document.getElementById('death-grid').innerHTML = stats.map(function(x){
    return '<div class="death-stat"><div class="death-stat-l">'+x[0]+'</div><div class="death-stat-v">'+x[1]+'</div></div>';
  }).join('');
  document.getElementById('death-em').textContent = G.age>80?'RIP':G.health<=0?'RIP':G.arrests>=3?'JAILED':'RIP';
  document.getElementById('death-overlay').classList.add('show');
  document.getElementById('btn-age').disabled = true;
}

// ============================================================
//  RESET
// ============================================================
function resetGame() {
  G=null; waiting=false; selectedGender='female'; selectedSkin='light';
  document.getElementById('death-overlay').classList.remove('show');
  document.getElementById('setup-card').classList.remove('hidden');
  ['char-card','stats-card','main-panel','choice-card'].forEach(function(id){
    document.getElementById(id).classList.add('hidden');
  });
  const aa = document.getElementById('action-area');
  aa.style.display='none'; aa.classList.add('hidden');
  document.getElementById('log').innerHTML='';
  document.getElementById('inp-name').value='';
  document.getElementById('sel-country').value='';
  document.getElementById('sel-state').innerHTML='<option value="">-- Select Country First --</option>';
  document.getElementById('btn-age').disabled=false;
  setGender('female'); setSkin('light'); showTab('life');
}
