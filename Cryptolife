function getAvatar(G) {
  const s = SKIN[G.skin] || SKIN.light;
  const f = G.isFemale;
  const a = G.age;
  if ((G.career==='kingpin'||G.career==='cartel') && !f) return faceDreads(SKIN.dark);
  if (a < 3)  return faceBabe(s);
  if (a < 6)  return f ? faceFemaleToddler(s) : faceMaleToddler(s);
  if (a < 13) return f ? faceFemaleChild(s)   : faceMaleChild(s);
  if (a < 18) return f ? faceFemaleteen(s)    : faceMaleTeen(s);
  if (a < 26) return f ? femaleFaceYA(s)      : maleFaceYA(s);
  if (a < 51) return f ? femaleFaceAdult(s)   : maleFaceAdult(s);
  return f ? femaleFaceElder(s) : maleFaceElder(s);
}

